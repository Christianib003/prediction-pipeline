{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "_id",
    "created_at",
    "disease_id",
    "filename",
    "path",
    "plant_id",
    "split"
  ],
  "properties": {
    "_id": {
      "$ref": "#/$defs/ObjectId"
    },
    "created_at": {
      "$ref": "#/$defs/Date"
    },
    "disease_id": {
      "$ref": "#/$defs/ObjectId"
    },
    "filename": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "plant_id": {
      "$ref": "#/$defs/ObjectId"
    },
    "split": {
      "type": "string"
    }
  },
  "$defs": {
    "ObjectId": {
      "type": "object",
      "properties": {
        "$oid": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{24}$"
        }
      },
      "required": [
        "$oid"
      ],
      "additionalProperties": false
    },
    "Date": {
      "type": "object",
      "properties": {
        "$date": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "$date"
      ],
      "additionalProperties": false
    }
  }
}